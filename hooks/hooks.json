{
  "hooks": {
    "PostToolUse": [
      {
        "comment": "规则1: 自动瘦身检查",
        "matcher": "tool == 'Edit' || tool == 'Write'",
        "hooks": [
          {
            "command": "sh hooks/post-edit-length-check.sh \"$tool_input_file_path\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "comment": "规则1: 禁止废话提交",
        "matcher": "tool == 'Bash' && tool_input.command contains 'git commit'",
        "hooks": [
          {
            "command": "sh hooks/pre-commit-style-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "comment": "规则1: 会话结束提醒",
        "hooks": [
          {
            "command": "sh hooks/session-stop-reminder.sh"
          }
        ]
      }
    ]
  }
}