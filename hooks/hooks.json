{
  "hooks": {
    "PostToolUse": [
      {
        "comment": "规则: 自动瘦身检查",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh hooks/post-edit-length-check.sh \"$tool_input_file_path\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "comment": "规则: 禁止废话提交",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$tool_input_command\" | grep -q 'git commit'; then sh hooks/pre-commit-style-check.sh; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "comment": "规则: 会话结束提醒",
        "hooks": [
          {
            "type": "command",
            "command": "sh hooks/session-stop-reminder.sh"
          }
        ]
      }
    ]
  }
}